# STUDLYF Backend Configurations
DATABASE_URL=mongodb://mongodb:27017/studlyf

# Optional External API Keys (Fill to enable real AI / search functionality)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Supabase Configuration (Optional, falls back to MongoDB/MockDB)
# To use Supabase as your primary database, configure these variables AND create the 'collections' table in your Supabase dashboard using the SQL script.
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_BUCKET=studlyf-assets

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Resend Email Trigger API Key
RESEND_API_KEY=your_resend_api_key
